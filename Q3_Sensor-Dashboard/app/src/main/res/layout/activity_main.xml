<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ══════════════════════════ HEADER ══════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENSOR"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:letterSpacing="0.3"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="@color/text_primary"
                android:textSize="36sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Real-time device sensor readings"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ══════════════════════════ ACCELEROMETER CARD ══════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_accelerometer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/icon_bg_blue"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accelerometer"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <View
                                android:id="@+id/accel_indicator"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/indicator_active"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tv_accel_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Initializing..."
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m/s²"
                        android:textColor="@color/accent_blue"
                        android:textSize="11sp"
                        android:background="@drawable/badge_bg_blue"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp" />

                <!-- X Y Z Axis Boxes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- X -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/axis_bg_x"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="X AXIS"
                            android:textColor="@color/axis_x"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_accel_x"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.000"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Y -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/axis_bg_y"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Y AXIS"
                            android:textColor="@color/axis_y"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_accel_y"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.000"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Z -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/axis_bg_z"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Z AXIS"
                            android:textColor="@color/axis_z"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_accel_z"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.000"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════ LIGHT SENSOR CARD ══════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/icon_bg_yellow"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Light Sensor"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <View
                                android:id="@+id/light_indicator"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/indicator_active"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tv_light_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Initializing..."
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="lux"
                        android:textColor="@color/accent_yellow"
                        android:textSize="11sp"
                        android:background="@drawable/badge_bg_yellow"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp" />

                <!-- Big Value Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/value_bg_yellow"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_light_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— lx"
                        android:textColor="@color/text_primary"
                        android:textSize="44sp"
                        android:fontFamily="sans-serif-thin"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ambient Illuminance"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════ PROXIMITY SENSOR CARD ══════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_proximity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/icon_bg_green"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📡"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Proximity Sensor"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <View
                                android:id="@+id/proximity_indicator"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/indicator_active"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tv_proximity_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Initializing..."
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="cm"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:background="@drawable/badge_bg_green"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp" />

                <!-- Big Value Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/value_bg_green"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_proximity_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— cm"
                        android:textColor="@color/text_primary"
                        android:textSize="44sp"
                        android:fontFamily="sans-serif-thin"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance to Nearest Object"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Powered by Android SensorManager API"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

    </LinearLayout>
</ScrollView>